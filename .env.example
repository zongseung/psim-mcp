# =============================================================================
# PSIM-MCP 서버 환경 변수 설정
# 이 파일을 .env 로 복사한 뒤 값을 수정하세요.
# =============================================================================

# --- PSIM 연동 설정 ---
# 동작 모드: "mock" (모의 어댑터) 또는 "real" (실제 PSIM 연동)
PSIM_MODE=mock

# PSIM 설치 디렉터리 경로 (real 모드에서 필수)
# PSIM 2026 기본 설치 경로: C:\Powersim\PSIM
# PSIM_PATH=C:\Powersim\PSIM

# PSIM 번들 Python 3.8 실행 파일 경로
# PSIM_PYTHON_EXE=C:\Powersim\PSIM\python38\python.exe

# 기본 프로젝트 디렉터리
# PSIM_PROJECT_DIR=./projects

# 시뮬레이션 결과 출력 디렉터리
# PSIM_OUTPUT_DIR=./output

# --- 로깅 설정 ---
# 로그 파일 저장 경로
LOG_DIR=./logs

# 로그 레벨: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- 서버 설정 ---
# 전송 방식: "stdio" (Claude Desktop 기본) 또는 "sse"
SERVER_TRANSPORT=stdio

# SSE 모드에서 사용할 호스트 주소
SERVER_HOST=127.0.0.1

# SSE 모드에서 사용할 포트 번호
SERVER_PORT=8000

# --- 시뮬레이션 설정 ---
# 시뮬레이션 최대 대기 시간 (초)
# 복잡한 모터 드라이브 시뮬레이션은 10분 이상 걸릴 수 있으므로 필요 시 늘리세요.
SIMULATION_TIMEOUT=300

# 토폴로지별 기본 time_step/total_time이 자동 적용됩니다.
# 예: buck → 1us/20ms, llc → 100ns/5ms, bldc_drive → 1us/500ms
# 사용자가 명시적으로 지정하면 기본값을 덮어씁니다.

# 파라미터 스윕 최대 스텝 수
MAX_SWEEP_STEPS=100

# --- 보안 설정 ---
# 허용된 프로젝트 디렉터리 목록 (쉼표로 구분, 비어있으면 제한 없음)
# ALLOWED_PROJECT_DIRS=/path/to/projects,/another/path
